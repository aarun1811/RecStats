# RecViz — Citi laptop / Windows profile template.
#
# Copy to backend/.env on the Citi laptop, then replace every <CITI_*>
# placeholder with the real value. The backend refuses to start if
# RECVIZ_DB_URL or RECVIZ_ENCRYPTION_KEY are missing.
#
# Differences from .env.example (the macOS-Docker dev template):
#   - DB URL points at real Citi Oracle (plain JDBC, no TLS wallet)
#   - Oracle Instant Client path uses Windows-style location
#   - CORS + frame-ancestors permit rectrace dev origin (http://localhost:5173)
#     so the rectrace iframe can embed RecViz dashboards
#
# This file is committed with placeholders. After filling in real credentials,
# DO NOT git push the filled .env back to the public GitHub remote — keep
# the filled version local to your Citi machine only.

# ─── Oracle (RecViz catalog DB) ───────────────────────────────────────────────
# Plain JDBC URL — same Oracle instance as rectrace, same shape:
#   oracle+oracledb://<user>:<password>@<host>:<port>/?service_name=<service>
# The RECVIZ schema holds recviz_connections / recviz_datasets / recviz_kpis /
# recviz_dashboards. Your DBA may have already created the schema + tables
# via the migration script.
RECVIZ_DB_URL=oracle+oracledb://<CITI_RECVIZ_USER>:<CITI_RECVIZ_PASSWORD>@<CITI_ORACLE_HOST>:<CITI_ORACLE_PORT>/?service_name=<CITI_ORACLE_SERVICE>
RECVIZ_DB_SCHEMA=<CITI_RECVIZ_SCHEMA>

# ─── Oracle Instant Client (REQUIRED, thick-mode enforcement) ─────────────────
# Windows: install Citi-approved Instant Client 21+ and point at the lib
# directory. Forward slashes work on Windows for env vars; back slashes work
# too but need escaping in some shells. Examples (pick whichever matches
# your install):
#   C:/oracle/instantclient_21_13
#   D:/tools/oracle/instantclient
ORACLE_CLIENT_LIB_DIR=<CITI_ORACLE_INSTANTCLIENT_PATH>

# ─── Fernet encryption key ────────────────────────────────────────────────────
# Encrypts passwords stored in recviz_connections.encrypted_password.
# Generate ONCE on the laptop with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Reuse the same key across restarts (otherwise stored connection passwords
# become unreadable).
RECVIZ_ENCRYPTION_KEY=<GENERATE_VIA_FERNET>

# ─── CORS allow-list ──────────────────────────────────────────────────────────
# Permit the rectrace Vite dev server (http://localhost:5173) so the React
# app can call RecViz APIs cross-origin. Plus self for direct browser hits.
RECVIZ_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# ─── Embed frame-ancestors (X-Frame-Options / CSP) ────────────────────────────
# Permit rectrace's React dev origin to embed RecViz dashboards in an iframe.
# Space-separated list (Content-Security-Policy frame-ancestors syntax).
RECVIZ_EMBED_FRAME_ANCESTORS=http://localhost:5173 http://127.0.0.1:5173

# ─── Frontend API base URL ────────────────────────────────────────────────────
# Leave EMPTY for same-origin deploys (FastAPI serves both backend + frontend
# from the same uvicorn port — API calls become relative `/api/...` paths,
# work from any host). Only set this to an absolute URL if you're running the
# Vite dev server cross-origin to uvicorn (e.g. dev on :5173 hitting API on
# :8000) — note that requires a rebuild since Vite bakes this in at build
# time, not runtime.
VITE_API_BASE_URL=
