# RecViz Backend Configuration
# Copy to .env and customize for your environment

# Superset connection (will be removed in Phase 15)
SUPERSET_URL=http://localhost:8088
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin

# Redis (will be removed in Phase 15)
REDIS_URL=redis://localhost:6379/0

# RecViz metadata database (PostgreSQL in dev, Oracle in prod)
RECVIZ_DB_URL=postgresql+asyncpg://recviz:recviz_dev@localhost:5432/superset_meta

# Recon data database
RECON_DB_URL=postgresql://recviz:recviz_dev@localhost:5432/recon_data

# Fernet encryption key for database credentials at rest
# Generate a new key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production -- the default is for local dev only
RECVIZ_ENCRYPTION_KEY=ZtmS2OQUhct4iBQmAcreQftJoeodRw4h7Rz3fU8ZPG4=
