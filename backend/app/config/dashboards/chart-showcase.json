{
  "id": "chart-showcase",
  "name": "Chart Type Showcase",
  "description": "Test dashboard exercising all supported chart types with dedicated data sources",
  "features": {
    "cross_filter": true,
    "drill_down": true
  },
  "filters": [],
  "kpis": [],
  "charts": [
    {
      "id": "sc-bar",
      "title": "Bar Chart",
      "type": "bar",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_categories", "metric": "revenue" }],
      "layout": { "col": 1, "row": 1, "width": 6, "height": 1 },
      "cross_filter": true,
      "drill_hierarchy": ["department"]
    },
    {
      "id": "sc-stacked-bar",
      "title": "Stacked Bar Chart",
      "type": "stacked-bar",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_categories", "metric": "revenue" },
        { "data_source_id": "showcase_categories", "metric": "headcount" }
      ],
      "layout": { "col": 7, "row": 1, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-line",
      "title": "Line Chart",
      "type": "line",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_timeseries", "metric": "processed_count" },
        { "data_source_id": "showcase_timeseries", "metric": "exception_count" }
      ],
      "layout": { "col": 1, "row": 2, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-area",
      "title": "Area Chart",
      "type": "area",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_timeseries", "metric": "processed_count" },
        { "data_source_id": "showcase_timeseries", "metric": "exception_count" }
      ],
      "layout": { "col": 7, "row": 2, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-pie",
      "title": "Pie Chart",
      "type": "pie",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_distribution", "metric": "item_count" }],
      "layout": { "col": 1, "row": 3, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-donut",
      "title": "Donut Chart",
      "type": "donut",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_distribution", "metric": "item_count" }],
      "layout": { "col": 7, "row": 3, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-scatter",
      "title": "Scatter Chart",
      "type": "scatter",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_scatter", "metric": "processing_time_ms" },
        { "data_source_id": "showcase_scatter", "metric": "record_count" },
        { "data_source_id": "showcase_scatter", "metric": "error_rate" }
      ],
      "layout": { "col": 1, "row": 4, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-heatmap",
      "title": "Heatmap",
      "type": "heatmap",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_heatmap", "metric": "match_count" }],
      "layout": { "col": 7, "row": 4, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-treemap",
      "title": "Treemap",
      "type": "treemap",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_treemap", "metric": "total_volume" },
        { "data_source_id": "showcase_treemap", "metric": "net_change" }
      ],
      "layout": { "col": 1, "row": 5, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-waterfall",
      "title": "Waterfall Chart",
      "type": "waterfall",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_waterfall", "metric": "amount" }],
      "layout": { "col": 7, "row": 5, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-combo",
      "title": "Combo Chart (Bar + Line)",
      "type": "combo",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_categories", "metric": "revenue" },
        { "data_source_id": "showcase_categories", "metric": "headcount" }
      ],
      "layout": { "col": 1, "row": 6, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-funnel",
      "title": "Funnel (ECharts)",
      "type": "funnel",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_funnel", "metric": "count" }],
      "layout": { "col": 7, "row": 6, "width": 6, "height": 1 },
      "cross_filter": true
    },
    {
      "id": "sc-histogram",
      "title": "Histogram",
      "type": "histogram",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_scatter", "metric": "record_count" }],
      "layout": { "col": 1, "row": 7, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-sankey",
      "title": "Sankey (ECharts)",
      "type": "sankey",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_sankey", "metric": "value" }],
      "layout": { "col": 7, "row": 7, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-radar",
      "title": "Radar (ECharts)",
      "type": "radar",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_radar", "metric": "score" },
        { "data_source_id": "showcase_radar", "metric": "benchmark" }
      ],
      "layout": { "col": 1, "row": 8, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-gauge",
      "title": "Gauge (ECharts)",
      "type": "gauge",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_gauge", "metric": "value" }],
      "layout": { "col": 7, "row": 8, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-graph",
      "title": "Graph / Network (ECharts)",
      "type": "graph",
      "source_type": "query",
      "sources": [{ "data_source_id": "showcase_sankey", "metric": "value" }],
      "layout": { "col": 1, "row": 9, "width": 6, "height": 1 },
      "cross_filter": false
    },
    {
      "id": "sc-parallel",
      "title": "Parallel Coordinates (ECharts)",
      "type": "parallel",
      "source_type": "query",
      "sources": [
        { "data_source_id": "showcase_scatter", "metric": "processing_time_ms" },
        { "data_source_id": "showcase_scatter", "metric": "record_count" },
        { "data_source_id": "showcase_scatter", "metric": "error_rate" }
      ],
      "layout": { "col": 7, "row": 9, "width": 6, "height": 1 },
      "cross_filter": false
    }
  ],
  "_comments": {
    "sunburst_skipped": "Sunburst chart type is supported in the ECharts wrapper but requires hierarchical JSON data (name/value/children). Our SQL-based data pipeline returns flat rows, so sunburst cannot be exercised through the standard query pipeline. It would need a custom data transformation layer or a dedicated API endpoint returning nested JSON."
  },
  "grids": [],
  "layout": {
    "type": "standard",
    "sections": ["charts"]
  }
}
