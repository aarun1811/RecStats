# ResStats Environment Configuration

# Application
APP_NAME=ResStats
APP_VERSION=0.1.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./resstats.db

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:4200", "http://127.0.0.1:4200"]

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Oracle connection (optional)
# ORACLE_HOST=localhost
# ORACLE_PORT=1521
# ORACLE_SERVICE_NAME=ORCL
# ORACLE_USER=your_user
# ORACLE_PASSWORD=your_password

# Hive connection (optional)
# HIVE_HOST=localhost
# HIVE_PORT=10000
# HIVE_DATABASE=default
# HIVE_USER=your_user
# HIVE_PASSWORD=your_password

# ag-grid Enterprise License (for frontend)
# AG_GRID_LICENSE_KEY=your_license_key_here
