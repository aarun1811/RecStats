# RecViz frontend — local build-time env (Vite). Copy to `.env.local` and fill in.
# `.env.local` is gitignored (`*.local`); never commit the real key.
#
# AG Grid Enterprise + AG Charts Enterprise license key. ONE key covers both
# (RecViz uses both packages). Same mechanism as rectrace's
# frontend-react/.env.local.example. Read in src/main.tsx via import.meta.env.
#
# This is a BUILD-TIME var — after setting it, rebuild the frontend:
#   cd frontend && pnpm build      # FastAPI then serves the licensed bundle at :8000
# (or restart `pnpm dev` if running the Vite dev server directly).
VITE_AG_GRID_LICENSE_KEY=

# Optional: backend API base URL for cross-origin dev (default same-origin).
# VITE_API_BASE_URL=http://localhost:8000

# Optional: hide the "Open in RecViz" link in the embedded dashboard view so
# users inside the rectrace iframe can't navigate out to the standalone RecViz
# app. BUILD-TIME var — set to true and rebuild the frontend. Default (unset)
# SHOWS the link. Citi prod sets this to true.
# VITE_EMBED_HIDE_OPEN_IN_LINK=true
